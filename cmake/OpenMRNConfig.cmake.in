@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find dependencies
if(UNIX AND NOT APPLE)
    find_dependency(Threads REQUIRED)
elseif(APPLE)
    find_dependency(Threads REQUIRED)
endif()

# Include targets file
include("${CMAKE_CURRENT_LIST_DIR}/OpenMRNTargets.cmake")

# Check required components
check_required_components(OpenMRN)

# Provide OPENMRNPATH variable for compatibility
set(OPENMRNPATH "${PACKAGE_PREFIX_DIR}")
